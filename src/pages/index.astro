<!-- ======================================================== -->


<section class="py-40 bg-[#0C0C10]">
  <div class="container mx-auto px-6">

    <div class="grid lg:grid-cols-12 gap-20">
      <div class="lg:col-span-5">
         <h2 class="text-5xl md:text-7xl font-bold text-white tracking-tightest leading-none">
          Our Mission <br /> & Values.
        </h2>
      </div>

      <div class="lg:col-span-7 grid gap-16 border-l border-white/5 pl-12">
        <div>
          <h4 class="text-brand-gold text-[10px] font-bold uppercase tracking-[0.4em] mb-4 font-mono">// Our Mission</h4>
          <p class="text-white text-xl leading-relaxed font-light">
            To provide affordable, high-quality digital and ICT services that empower
            individuals and businesses to succeed in a technology-driven world.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12">
          <div>
            <h4 class="text-white font-bold mb-4 uppercase text-xs tracking-widest">Innovation</h4>
            <p class="text-white text-sm leading-relaxed">
              We continuously improve and create better ways to deliver effective
              technology solutions.
            </p>
          </div>
          <div>
            <h4 class="text-white font-bold mb-4 uppercase text-xs tracking-widest">Integrity & Empowerment</h4>
            <p class="text-white text-sm leading-relaxed">
              We build trust through transparency and help people unlock their potential
              through learning and digital growth.
            </p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>


<section class="py-48 bg-[#08080A] text-center border-t border-white/5 relative">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(212,175,55,0.05)_0%,transparent_70%)]"></div>
  
  <div class="container mx-auto px-6 max-w-4xl relative z-10">
    <h2 class="text-6xl md:text-9xl font-bold text-white mb-12 tracking-tightest leading-none">
      LET'S BUILD <br /> <span class="text-brand-gold italic">TOGETHER.</span>
    </h2>

    <p class="text-white text-xl mb-16 font-light max-w-2xl mx-auto">
      Whether you need a website, a digital solution, or tech training —
      we’re ready to help you take the next step.
    </p>

    <a href="/contact"
       class="inline-block px-12 py-6 bg-brand-gold text-black text-[11px] font-bold uppercase tracking-[0.4em] transition-all hover:bg-white">
      Contact Us Today
    </a>
  </div>
</section>

</Layout>

<style>
  .tracking-tightest { letter-spacing: -0.06em; }
</style>