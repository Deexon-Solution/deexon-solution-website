---
interface Props {
  title?: string;
}

const { title = "Deexon Solutions" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-black">
    <slot />
  </body>
</html>
