        <p class="text-white text-sm leading-relaxed max-w-xs">
          Engineering high-performance technology ecosystems and elite engineering talent for the global frontier.
        </p>

        <!-- Social Media -->
        <div class="flex gap-4">
          <!-- Whatsapp -->
          <a href="https://whatsapp.com/channel/0029VbBGY3z89inh2GZ2KN19" target="_blank" rel="noopener noreferrer" class="group relative flex items-center justify-center w-10 h-10">
            <img src="/icon/whatsapp.svg" alt="WhatsApp" class="w-5 h-5" />
          </a>

          <!-- Telegram -->
          <a href="https://t.me/deexonsolutions" target="_blank" rel="noopener noreferrer" class="group relative flex items-center justify-center w-10 h-10">
